{
    "extends": "@univerjs-infra/shared/tsconfigs/node",
    "compilerOptions": {
        "rootDir": "src",
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false,
        "outDir": "lib/types"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/**/__tests__/**",
        "src/**/*.spec.ts",
        "src/**/*.test.ts"
    ]
}
