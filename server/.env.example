PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/enterprise_ops
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10
# 测试用独立库(测试会清空 app_user/operation_log,务必用独立库,避免误伤)
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/enterprise_ops_test

# 豆包 AI(火山方舟 Ark,OpenAI 兼容)。不配 DOUBAO_API_KEY 则 AI 助手提示未配置
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-1-pro-260628
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 文生图模型(海报背景)。doubao-seedream-5-0-pro 触发账号安全体验限额,用 4-0
POSTER_MODEL=doubao-seedream-4-0-250828

# AI 抽取管线(子项目3)。默认复用 DOUBAO_MODEL;调度 cron 默认每天 02:17
EXTRACT_MODEL=
EXTRACT_CRON=17 2 * * *
EXTRACT_TIMEOUT_MS=60000
